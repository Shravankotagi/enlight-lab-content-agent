# Content Agent — Agent 03 — Environment Variables
# Copy this file to .env and fill in the real values before starting the service.

# Supabase project URL (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=your_supabase_project_url_here

# Supabase service-role key (Settings > API > service_role secret)
# WARNING: Do NOT expose this key in the frontend / browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Bearer token that callers (dashboard) must send in Authorization header.
# Generate any long random string, e.g.: openssl rand -hex 32
CONTENT_AGENT_API_KEY=your_content_agent_api_key_here

# Optional: override the port (default: 8001)
# PORT=8001
